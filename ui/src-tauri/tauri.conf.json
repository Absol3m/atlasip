{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AtlasIP",
  "version": "0.3.0",
  "identifier": "atlas.ip",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "AtlasIP",
        "width": 1200,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon_32.png",
      "icons/icon_128.png",
      "icons/icon_256.png",
      "icons/icon_512.png",
      "icons/icon_1024.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
